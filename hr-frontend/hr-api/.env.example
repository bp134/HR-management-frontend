# Server
PORT=3001
NODE_ENV=development

# Comma-separated browser origins (Vercel + local)
CORS_ORIGINS=http://localhost:5173

# Microsoft Entra ID — API app registration
AZURE_TENANT_ID=be524202-3d24-49b4-ad01-17fffd89b958
# Application (client) ID of the HR API app registration
AZURE_API_CLIENT_ID=e005eb5b-ab79-4dac-acbf-219b961fc75f

# Azure PostgreSQL — Entra ID auth (recommended for local dev: run `az login` first)
DATABASE_AUTH=entra
DATABASE_HOST=psql-msc-tst-uks-134.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=Employeedb
DATABASE_USER=info@belfieldpharmacy.co.uk

# Or password auth (sslmode=require is appended automatically if missing)
# DATABASE_AUTH=password
# DATABASE_URL=postgresql://user:password@host:5432/Employeedb?sslmode=require
