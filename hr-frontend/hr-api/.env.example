# Server
PORT=3001
NODE_ENV=development

# Comma-separated browser origins (Vercel + local)
CORS_ORIGINS=http://localhost:5173

# Microsoft Entra ID — API app registration
AZURE_TENANT_ID=your-tenant-id
# Application (client) ID of the HR API app registration
AZURE_API_CLIENT_ID=your-api-client-id

# Azure PostgreSQL — Entra ID auth (recommended for local dev: run `az login` first)
DATABASE_AUTH=entra
DATABASE_HOST=your-server.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=your-database-name
DATABASE_USER=your-db-user@yourdomain.com

# Or password auth — use discrete vars on Render (recommended; avoids URL-encoding @ in usernames)
# DATABASE_AUTH=password
# DATABASE_HOST=your-server.postgres.database.azure.com
# DATABASE_PORT=5432
# DATABASE_NAME=Employeedb
# DATABASE_USER=your-admin-user
# DATABASE_PASSWORD=your-password
#
# Or a single URL (encode @ in username/password as %40)
# DATABASE_URL=postgresql://user%40domain:password@host:5432/Employeedb?sslmode=require
