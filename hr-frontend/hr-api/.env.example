# Server
PORT=3001
NODE_ENV=development

# Comma-separated browser origins (Vercel + local)
CORS_ORIGINS=http://localhost:5173

# Microsoft Entra ID — API app registration
AZURE_TENANT_ID=your-tenant-id
# Application (client) ID of the HR API app registration
AZURE_API_CLIENT_ID=your-api-client-id

# Azure PostgreSQL — Entra ID auth (recommended for local dev: run `az login` first)
DATABASE_AUTH=entra
DATABASE_HOST=your-server.postgres.database.azure.com
DATABASE_PORT=5432
DATABASE_NAME=your-database-name
DATABASE_USER=your-db-user@yourdomain.com

# Or password auth (sslmode=require is appended automatically if missing)
# DATABASE_AUTH=password
# DATABASE_URL=postgresql://user:password@host:5432/your-database-name?sslmode=require
