# Entra ID — SPA app registration (frontend)
VITE_AZURE_CLIENT_ID=your-spa-client-id
VITE_AZURE_TENANT_ID=your-tenant-id

# API scope from Entra → API app → Expose an API (e.g. api://<api-client-id>/access_as_user)
VITE_AZURE_API_SCOPE=api://your-api-client-id/access_as_user

# HR API base URL (local dev: http://localhost:3001, prod: https://your-api.azurewebsites.net)
VITE_API_BASE_URL=http://localhost:3001
